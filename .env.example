# 문서 디렉토리 (기본: data/documents/)
# DOCUMENTS_DIR=data/documents/

# ChromaDB 저장 경로 (기본: data/chroma_db/)
# CHROMA_PERSIST_DIR=data/chroma_db/

# LLM 모델명 (기본: gpt-5.3-codex)
# LLM_MODEL=gpt-5.3-codex

# 임베딩 모델 (기본: upskyy/bge-m3-korean)
# EMBED_MODEL=upskyy/bge-m3-korean

# 청크 설정
# CHUNK_SIZE=512
# CHUNK_OVERLAP=64

# 검색 설정
# TOP_K=5

# Discord 봇
RAG_DISCORD_BOT_TOKEN=your_discord_bot_token_here
RAG_DISCORD_CHANNEL_ID=0
